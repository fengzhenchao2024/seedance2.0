{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "Collection of user profiles"
    }
  }
}
